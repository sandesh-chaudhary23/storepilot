# ─── Core ───────────────────────────────────────────────
PORT=5050
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Database ───────────────────────────────────────────
# Paste your MongoDB Atlas connection string here.
# If left blank, the server boots an in-memory MongoDB (data resets on restart).
MONGODB_URI=

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false

# ─── AI (Google Gemini) ─────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# If left blank, AI endpoints return a deterministic mock.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Image uploads (Cloudinary) ─────────────────────────
# If left blank, images are stored on local disk under /uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (password reset via SMTP) ────────────────────
# If left blank, a test Ethereal inbox is used and the preview URL is logged.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="StorePilot <no-reply@storepilot.app>"
